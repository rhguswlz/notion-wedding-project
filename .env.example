# Notion API 설정
# Notion Integration 토큰 (https://www.notion.so/my-integrations에서 생성)
NOTION_TOKEN=your_notion_token_here

# Notion 카테고리 데이터베이스 ID
NOTION_CATEGORY_DATABASE_ID=your_category_database_id_here

# Notion 포스트/아이템 데이터베이스 ID
NOTION_ITEMS_DATABASE_ID=your_items_database_id_here

# 앱 설정
NEXT_PUBLIC_APP_URL=http://localhost:3000
